<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================ -->
    <!-- Module Category                                                -->
    <!-- ============================================================ -->
    <record id="module_category_nl2sql" model="ir.module.category">
        <field name="name">NL2SQL Dashboard</field>
        <field name="description">Natural Language SQL Management Dashboard</field>
        <field name="sequence">50</field>
    </record>

    <!-- ============================================================ -->
    <!-- Security Groups                                                -->
    <!-- ============================================================ -->
    <record id="group_nl2sql_user" model="res.groups">
        <field name="name">NL2SQL User</field>
        <field name="comment">Can execute NL2SQL queries and view results</field>
        <field name="category_id" ref="module_category_nl2sql"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_nl2sql_manager" model="res.groups">
        <field name="name">NL2SQL Manager</field>
        <field name="comment">Can manage schema metadata, shared queries, and settings</field>
        <field name="category_id" ref="module_category_nl2sql"/>
        <field name="implied_ids" eval="[(4, ref('group_nl2sql_user'))]"/>
    </record>

    <!-- ============================================================ -->
    <!-- Record Rules                                                   -->
    <!-- ============================================================ -->

    <!-- Users see only their own query history -->
    <record id="rule_query_history_user" model="ir.rule">
        <field name="name">NL2SQL: Own query history</field>
        <field name="model_id" ref="model_nl2sql_query_history"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_nl2sql_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Managers see all query history -->
    <record id="rule_query_history_manager" model="ir.rule">
        <field name="name">NL2SQL: All query history (manager)</field>
        <field name="model_id" ref="model_nl2sql_query_history"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_nl2sql_manager'))]"/>
    </record>

    <!-- Users see own + shared saved queries -->
    <record id="rule_saved_query_user" model="ir.rule">
        <field name="name">NL2SQL: Own + shared saved queries</field>
        <field name="model_id" ref="model_nl2sql_saved_query"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), ('is_shared', '=', True)]</field>
        <field name="groups" eval="[(4, ref('group_nl2sql_user'))]"/>
    </record>

    <!-- Managers see all saved queries -->
    <record id="rule_saved_query_manager" model="ir.rule">
        <field name="name">NL2SQL: All saved queries (manager)</field>
        <field name="model_id" ref="model_nl2sql_saved_query"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_nl2sql_manager'))]"/>
    </record>

    <!-- Dashboard config: own only -->
    <record id="rule_dashboard_config_user" model="ir.rule">
        <field name="name">NL2SQL: Own dashboard config</field>
        <field name="model_id" ref="model_nl2sql_dashboard_config"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_nl2sql_user'))]"/>
    </record>
</odoo>
