<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================ -->
    <!-- NL2SQL Example — Tree + Form                                   -->
    <!-- ============================================================ -->
    <record id="view_nl2sql_example_tree" model="ir.ui.view">
        <field name="name">nl2sql.example.tree</field>
        <field name="model">nl2sql.example</field>
        <field name="arch" type="xml">
            <list string="Few-Shot Beispiele" decoration-muted="not is_active">
                <field name="domain" widget="badge"
                       decoration-info="domain == 'machines'"
                       decoration-success="domain == 'casting'"
                       decoration-warning="domain == 'scm'"/>
                <field name="difficulty" widget="badge"
                       decoration-success="difficulty == '1'"
                       decoration-warning="difficulty == '2'"
                       decoration-danger="difficulty == '3'"/>
                <field name="question"/>
                <field name="source_code"/>
                <field name="is_active" widget="boolean_toggle"/>
                <field name="synced" widget="boolean"/>
                <field name="created_at" optional="hide"/>
                <button name="action_sync_to_aifw" type="object"
                        string="→ aifw" icon="fa-upload"
                        class="btn-sm btn-secondary"/>
            </list>
        </field>
    </record>

    <record id="view_nl2sql_example_form" model="ir.ui.view">
        <field name="name">nl2sql.example.form</field>
        <field name="model">nl2sql.example</field>
        <field name="arch" type="xml">
            <form string="Few-Shot Beispiel">
                <header>
                    <button name="action_sync_to_aifw" type="object"
                            string="Zu aifw senden" class="btn-primary"
                            icon="fa-upload"/>
                    <field name="synced" widget="statusbar"
                           statusbar_visible="0,1"/>
                </header>
                <sheet>
                    <group>
                        <group string="Klassifikation">
                            <field name="source_code"/>
                            <field name="domain"/>
                            <field name="difficulty"/>
                            <field name="is_active"/>
                        </group>
                        <group string="Meta">
                            <field name="aifw_id"/>
                            <field name="synced"/>
                            <field name="created_at"/>
                        </group>
                    </group>
                    <group string="Frage">
                        <field name="question" nolabel="1"
                               placeholder="Natürlichsprachliche Frage exakt wie der User sie stellen würde…"/>
                    </group>
                    <group string="Verifiziertes SQL">
                        <field name="sql" nolabel="1" widget="code"
                               placeholder="SELECT … — gegen echte DB getestet"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nl2sql_example_search" model="ir.ui.view">
        <field name="name">nl2sql.example.search</field>
        <field name="model">nl2sql.example</field>
        <field name="arch" type="xml">
            <search string="Few-Shot Beispiele">
                <field name="question" string="Frage"/>
                <field name="domain"/>
                <field name="source_code"/>
                <filter name="active" string="Aktiv" domain="[('is_active','=',True)]"/>
                <filter name="not_synced" string="Nicht synchronisiert"
                        domain="[('synced','=',False)]"/>
                <separator/>
                <filter name="machines" string="Maschinen"
                        domain="[('domain','=','machines')]"/>
                <filter name="casting" string="Gießaufträge"
                        domain="[('domain','=','casting')]"/>
                <filter name="scm" string="SCM"
                        domain="[('domain','=','scm')]"/>
                <group>
                    <filter name="group_domain" string="Domäne"
                            context="{'group_by': 'domain'}"/>
                    <filter name="group_difficulty" string="Schwierigkeitsgrad"
                            context="{'group_by': 'difficulty'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_nl2sql_example" model="ir.actions.act_window">
        <field name="name">Few-Shot Beispiele</field>
        <field name="res_model">nl2sql.example</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Noch keine Few-Shot Beispiele vorhanden.
            </p>
            <p>
                Erstelle verifizierte Frage→SQL-Paare um die LLM-Qualität zu verbessern.
                Klicke auf <b>Zu aifw senden</b> um sie in den Prompt zu übernehmen.
            </p>
        </field>
    </record>
</odoo>
