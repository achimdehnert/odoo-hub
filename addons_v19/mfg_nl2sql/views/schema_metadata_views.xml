<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_schema_table_list" model="ir.ui.view">
        <field name="name">nl2sql.schema.table.list</field>
        <field name="model">nl2sql.schema.table</field>
        <field name="arch" type="xml">
            <list string="Schema-Tabellen" editable="bottom">
                <field name="domain"/>
                <field name="name"/>
                <field name="model_name"/>
                <field name="description"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_schema_table_form" model="ir.ui.view">
        <field name="name">nl2sql.schema.table.form</field>
        <field name="model">nl2sql.schema.table</field>
        <field name="arch" type="xml">
            <form string="Schema-Tabelle">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="model_name"/>
                            <field name="domain"/>
                            <field name="is_active"/>
                        </group>
                        <group>
                            <field name="description"/>
                            <field name="sample_queries"
                                   placeholder="Wie viele offene Bestellungen gibt es?&#10;Welcher Lieferant hat die höchste Bewertung?"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Spalten" name="columns">
                            <field name="column_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="data_type"/>
                                    <field name="description"/>
                                    <field name="is_primary_key"/>
                                    <field name="foreign_key_table"/>
                                    <field name="selection_values"/>
                                    <field name="is_active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_schema_table_search" model="ir.ui.view">
        <field name="name">nl2sql.schema.table.search</field>
        <field name="model">nl2sql.schema.table</field>
        <field name="arch" type="xml">
            <search string="Schema-Tabellen">
                <field name="name"/>
                <field name="model_name"/>
                <filter name="active" string="Aktiv"
                        domain="[('is_active','=',True)]"/>
                <group expand="0" string="Gruppieren">
                    <filter name="group_domain" string="Domäne"
                            context="{'group_by': 'domain'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_schema_table" model="ir.actions.act_window">
        <field name="name">Schema-Metadaten</field>
        <field name="res_model">nl2sql.schema.table</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
