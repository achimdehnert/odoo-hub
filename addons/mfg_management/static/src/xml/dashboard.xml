<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<!-- ═══════════════════════════════════════════════════════════════════
     KPI Card  (clickable if drilldownKey + onDrilldown are set)
     Optional: gaugeValue (0-100) renders SVG arc gauge instead of icon
════════════════════════════════════════════════════════════════════ -->
<t t-name="mfg_management.KpiCard">
    <div class="mfg-kpi-card"
         t-att-class="(props.colorClass or '') + (props.drilldownKey ? ' mfg-kpi-clickable' : '')"
         t-on-click="onClick">

        <!-- Gauge variant -->
        <t t-if="hasGauge">
            <div class="mfg-kpi-gauge">
                <svg viewBox="0 0 72 72" width="72" height="72">
                    <path class="mfg-gauge-track"
                          t-att-d="gaugeTrackPath"
                          fill="none" stroke="#e2e8f0" stroke-width="6" stroke-linecap="round"/>
                    <path class="mfg-gauge-arc"
                          t-att-d="gaugeArcPath"
                          fill="none"
                          t-att-stroke="gaugeStrokeColor"
                          stroke-width="6" stroke-linecap="round"
                          style="transition: stroke-dashoffset 0.6s ease"/>
                    <text x="36" y="40" text-anchor="middle"
                          class="mfg-gauge-text"
                          t-att-fill="gaugeStrokeColor">
                        <t t-esc="props.value"/>
                    </text>
                </svg>
            </div>
        </t>

        <!-- Icon variant -->
        <t t-if="!hasGauge">
            <div class="mfg-kpi-icon">
                <i t-att-class="'fa ' + (props.icon or 'fa-bar-chart')"/>
            </div>
        </t>

        <div class="mfg-kpi-body">
            <t t-if="!hasGauge">
                <div class="mfg-kpi-value"><t t-esc="props.value"/></div>
            </t>
            <div class="mfg-kpi-label"><t t-esc="props.label"/></div>
            <t t-if="props.sublabel">
                <div class="mfg-kpi-sublabel"><t t-esc="props.sublabel"/></div>
            </t>
        </div>
        <t t-if="props.drilldownKey">
            <div class="mfg-kpi-arrow"><i class="fa fa-chevron-right"/></div>
        </t>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════════════════
     Main Dashboard (Cockpit)
════════════════════════════════════════════════════════════════════ -->
<t t-name="mfg_management.Dashboard">
    <div class="mfg-dashboard">

        <!-- Header -->
        <div class="mfg-dashboard-header">
            <h1><i class="fa fa-industry"/> Manufacturing Cockpit</h1>
            <div class="mfg-header-controls">
                <button class="btn btn-sm btn-ai" t-on-click="toggleNl2sql">
                    <i class="fa fa-magic"/> KI-Abfrage
                </button>
                <button class="btn btn-sm btn-outline-secondary" t-on-click="loadData">
                    <i class="fa fa-refresh"/> Aktualisieren
                </button>
            </div>
        </div>

        <t t-if="state.loading">
            <div class="mfg-loading">
                <i class="fa fa-spinner fa-spin fa-3x"/>
                <p>Daten werden geladen…</p>
            </div>
        </t>

        <t t-if="!state.loading and state.data">

            <!-- ── NL2SQL Panel ───────────────────────────────────────── -->
            <t t-if="state.nl2sql.open">
                <div class="mfg-nl2sql-panel">
                    <div class="mfg-nl2sql-header">
                        <span><i class="fa fa-magic"/> KI-gestützte Datenabfrage (NL2SQL)</span>
                        <button class="mfg-nl2sql-close" t-on-click="toggleNl2sql"><i class="fa fa-times"/></button>
                    </div>

                    <!-- Suggest chips -->
                    <div class="mfg-nl2sql-suggests">
                        <t t-foreach="nl2sqlSuggestQueries()" t-as="sq" t-key="sq">
                            <button class="mfg-suggest-chip" t-on-click="() => this.applySuggest(sq)">
                                <t t-esc="sq"/>
                            </button>
                        </t>
                    </div>

                    <!-- Input row -->
                    <div class="mfg-nl2sql-input-row">
                        <textarea class="mfg-nl2sql-textarea"
                            placeholder="z.B. Welche Maschinen sind gerade in Störung? Zeige Aufträge mit Ausschuss &gt; 5%..."
                            t-att-value="state.nl2sql.query"
                            t-on-input="onNl2sqlInput"
                            rows="2"/>
                        <button class="btn btn-primary mfg-nl2sql-run"
                            t-att-disabled="state.nl2sql.loading or !state.nl2sql.query"
                            t-on-click="runNl2sql">
                            <t t-if="state.nl2sql.loading">
                                <i class="fa fa-spinner fa-spin"/> Läuft…
                            </t>
                            <t t-else="">
                                <i class="fa fa-play"/> Ausführen
                            </t>
                        </button>
                    </div>

                    <!-- Generated SQL -->
                    <t t-if="state.nl2sql.sql">
                        <div class="mfg-nl2sql-sql">
                            <span class="mfg-sql-label">SQL</span>
                            <code><t t-esc="state.nl2sql.sql"/></code>
                        </div>
                    </t>

                    <!-- Error -->
                    <t t-if="state.nl2sql.error">
                        <div class="mfg-nl2sql-error">
                            <i class="fa fa-exclamation-circle"/> <t t-esc="state.nl2sql.error"/>
                        </div>
                    </t>

                    <!-- Results table -->
                    <t t-if="nl2sqlHasRows()">
                        <div class="mfg-nl2sql-result">
                            <div class="mfg-nl2sql-result-meta">
                                <i class="fa fa-table"/>
                                <strong><t t-esc="state.nl2sql.result.row_count"/></strong> Zeilen
                                <span class="text-muted"> · <t t-esc="state.nl2sql.result.execution_time_ms"/> ms</span>
                            </div>
                            <div class="mfg-nl2sql-table-wrap">
                                <table class="mfg-table mfg-nl2sql-table">
                                    <thead>
                                        <tr>
                                            <t t-foreach="state.nl2sql.result.columns" t-as="col" t-key="col.name">
                                                <th><t t-esc="col.name"/></th>
                                            </t>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.nl2sql.result.rows" t-as="row" t-key="row_index">
                                            <tr>
                                                <t t-foreach="row" t-as="cell" t-key="cell_index">
                                                    <td><t t-esc="cell"/></td>
                                                </t>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </t>

                    <t t-if="state.nl2sql.result and !nl2sqlHasRows() and !state.nl2sql.error">
                        <div class="mfg-nl2sql-empty">
                            <i class="fa fa-inbox"/> Keine Ergebnisse
                        </div>
                    </t>
                </div>
            </t>

            <!-- ── KPI Row ────────────────────────────────────────────── -->
            <div class="mfg-kpi-row">
                <KpiCard
                    icon="'fa-tasks'"
                    label="'Aktive Aufträge (Guss)'"
                    value="activecastingOrders()"
                    colorClass="'kpi-blue'"
                    drilldownKey="'casting_active'"
                    onDrilldown.bind="openDrilldown"/>
                <KpiCard
                    icon="'fa-cogs'"
                    label="'Fertigung in Progress'"
                    value="state.data.scm_production.in_progress"
                    colorClass="'kpi-orange'"
                    drilldownKey="'scm_in_progress'"
                    onDrilldown.bind="openDrilldown"/>
                <KpiCard
                    icon="'fa-wrench'"
                    label="'Maschinen Betrieb'"
                    value="state.data.machines.operational"
                    colorClass="'kpi-green'"
                    drilldownKey="'machines_op'"
                    onDrilldown.bind="openDrilldown"/>
                <KpiCard
                    icon="'fa-exclamation-triangle'"
                    label="'Maschinen Störung'"
                    value="state.data.machines.breakdown"
                    colorClass="'kpi-red'"
                    drilldownKey="'machines_fail'"
                    onDrilldown.bind="openDrilldown"/>
                <KpiCard
                    label="'QS-Rate'"
                    value="state.data.quality.pass_rate + '%'"
                    sublabel="state.data.quality.total + ' Prüfungen'"
                    colorClass="'kpi-teal'"
                    drilldownKey="'quality'"
                    onDrilldown.bind="openDrilldown"
                    gaugeValue="state.data.quality.pass_rate"/>
                <KpiCard
                    icon="'fa-shopping-cart'"
                    label="'Offene Bestellungen'"
                    value="openPurchases()"
                    colorClass="'kpi-purple'"
                    drilldownKey="'purchases_open'"
                    onDrilldown.bind="openDrilldown"/>
            </div>

            <!-- ── Drilldown Overlay ──────────────────────────────────── -->
            <t t-if="state.drilldown">
                <div class="mfg-drilldown-backdrop" t-on-click="closeDrilldown"/>
                <div class="mfg-drilldown-panel">
                    <div class="mfg-drilldown-header">
                        <h2><i class="fa fa-search"/> <t t-esc="drilldownTitle()"/></h2>
                        <button class="mfg-drilldown-close" t-on-click="closeDrilldown">
                            <i class="fa fa-times"/>
                        </button>
                    </div>

                    <t t-if="state.drilldownLoading">
                        <div class="mfg-loading" style="min-height:120px">
                            <i class="fa fa-spinner fa-spin fa-2x"/>
                        </div>
                    </t>

                    <t t-if="!state.drilldownLoading and state.drilldownData">
                        <t t-if="state.drilldownData.error">
                            <div class="mfg-nl2sql-error"><i class="fa fa-exclamation-circle"/> <t t-esc="state.drilldownData.error"/></div>
                        </t>

                        <!-- Casting orders drilldown -->
                        <t t-if="state.drilldown === 'casting_active' and state.drilldownData.rows">
                            <table class="mfg-table">
                                <thead><tr><th>Auftrag</th><th>Status</th><th>Geplant</th><th>Stück</th><th>Ausschuss%</th><th>Kunde</th></tr></thead>
                                <tbody>
                                    <t t-foreach="state.drilldownData.rows" t-as="r" t-key="r.id">
                                        <tr>
                                            <td class="mfg-monospace"><t t-esc="r.name"/></td>
                                            <td><span class="mfg-badge" t-att-class="'cast-' + r.state"><t t-esc="r.state"/></span></td>
                                            <td><t t-esc="r.date_planned or '—'"/></td>
                                            <td><t t-esc="r.total_pieces or 0"/></td>
                                            <td t-att-class="r.total_scrap_pct > 5 ? 'text-danger fw-bold' : ''">
                                                <t t-esc="r.total_scrap_pct or 0"/>%
                                            </td>
                                            <td class="text-muted"><t t-esc="r.customer_reference or '—'"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Machine drilldown (op + fail) -->
                        <t t-if="(state.drilldown === 'machines_op' or state.drilldown === 'machines_fail') and state.drilldownData.rows">
                            <table class="mfg-table">
                                <thead><tr><th>Code</th><th>Name</th><th>Typ</th><th>Halle</th><th>Status</th></tr></thead>
                                <tbody>
                                    <t t-foreach="state.drilldownData.rows" t-as="m" t-key="m.id">
                                        <tr>
                                            <td class="mfg-monospace"><t t-esc="m.code"/></td>
                                            <td><t t-esc="m.name"/></td>
                                            <td class="text-muted"><t t-esc="m.machine_type"/></td>
                                            <td class="text-muted"><t t-esc="m.hall or '—'"/></td>
                                            <td><span class="mfg-machine-state-badge" t-att-class="'sbadge-' + m.state"><t t-esc="m.state"/></span></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Quality drilldown -->
                        <t t-if="state.drilldown === 'quality' and state.drilldownData.summary">
                            <div class="mfg-drilldown-qs">
                                <div class="mfg-qs-big">
                                    <div class="mfg-qs-rate"><t t-esc="state.drilldownData.summary.pass_rate"/>%</div>
                                    <div class="mfg-qs-label">Bestehensrate</div>
                                </div>
                                <div class="mfg-qs-breakdown">
                                    <div class="mfg-qs-item qs-pass"><i class="fa fa-check-circle"/> Bestanden <strong><t t-esc="state.drilldownData.summary.pass"/></strong></div>
                                    <div class="mfg-qs-item qs-fail"><i class="fa fa-times-circle"/> Nicht bestanden <strong><t t-esc="state.drilldownData.summary.fail"/></strong></div>
                                    <div class="mfg-qs-item qs-cond"><i class="fa fa-exclamation-circle"/> Bedingt <strong><t t-esc="state.drilldownData.summary.conditional"/></strong></div>
                                </div>
                            </div>
                            <t t-if="state.drilldownData.rows and state.drilldownData.rows.length">
                                <table class="mfg-table" style="margin-top:16px">
                                    <thead><tr><th>Prüfung</th><th>Ergebnis</th><th>Datum</th><th>Prüfer</th></tr></thead>
                                    <tbody>
                                        <t t-foreach="state.drilldownData.rows" t-as="q" t-key="q.id">
                                            <tr>
                                                <td class="mfg-monospace"><t t-esc="q.name"/></td>
                                                <td><span class="mfg-badge" t-att-class="'qs-' + q.result"><t t-esc="q.result"/></span></td>
                                                <td><t t-esc="q.date_check or '—'"/></td>
                                                <td class="text-muted"><t t-esc="q.inspector_name or '—'"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                        </t>

                        <!-- Purchases drilldown -->
                        <t t-if="state.drilldown === 'purchases_open' and state.drilldownData.rows">
                            <table class="mfg-table">
                                <thead><tr><th>Nr.</th><th>Lieferant</th><th>Status</th><th>Erwartet</th><th class="text-end">Betrag €</th></tr></thead>
                                <tbody>
                                    <t t-foreach="state.drilldownData.rows" t-as="p" t-key="p.id">
                                        <tr>
                                            <td class="mfg-monospace"><t t-esc="p.name"/></td>
                                            <td><t t-esc="p.partner_name or '—'"/></td>
                                            <td><span class="mfg-badge" t-att-class="'po-' + p.state"><t t-esc="p.state"/></span></td>
                                            <td t-att-class="p.overdue ? 'text-danger fw-bold' : ''">
                                                <t t-esc="p.date_expected or '—'"/>
                                                <t t-if="p.overdue"> <i class="fa fa-warning"/></t>
                                            </td>
                                            <td class="text-end"><t t-esc="p.total_amount or 0"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- SCM drilldown -->
                        <t t-if="state.drilldown === 'scm_in_progress' and state.drilldownData.rows">
                            <table class="mfg-table">
                                <thead><tr><th>Auftrag</th><th>Teil</th><th>Status</th><th>Plan</th><th>Ist</th><th>Yield%</th></tr></thead>
                                <tbody>
                                    <t t-foreach="state.drilldownData.rows" t-as="s" t-key="s.id">
                                        <tr>
                                            <td class="mfg-monospace"><t t-esc="s.name"/></td>
                                            <td class="text-muted"><t t-esc="s.part_name or '—'"/></td>
                                            <td><span class="mfg-badge" t-att-class="'po-' + s.state"><t t-esc="s.state"/></span></td>
                                            <td><t t-esc="s.planned_qty or 0"/></td>
                                            <td><t t-esc="s.produced_qty or 0"/></td>
                                            <td t-att-class="(s.yield_pct or 0) &lt; 80 ? 'text-warning fw-bold' : 'text-success'">
                                                <t t-esc="s.yield_pct or 0"/>%
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <t t-if="state.drilldownData.rows and state.drilldownData.rows.length === 0">
                            <div class="mfg-nl2sql-empty"><i class="fa fa-inbox"/> Keine Einträge</div>
                        </t>
                    </t>
                </div>
            </t>

            <!-- ── Status Overview Grid ───────────────────────────────── -->
            <div class="mfg-section-grid">

                <!-- Casting Orders by State -->
                <div class="mfg-panel">
                    <h3><i class="fa fa-fire"/> Gießaufträge</h3>
                    <div class="mfg-state-bars">
                        <t t-foreach="castingOrderStates()" t-as="s" t-key="s.key">
                            <div class="mfg-state-bar-row mfg-state-bar-clickable" t-on-click="() => this.openDrilldown('casting_active')">
                                <span class="mfg-state-label"><t t-esc="s.label"/></span>
                                <div class="mfg-bar-track">
                                    <div class="mfg-bar-fill" t-att-style="'width:' + s.pct + '%;background:' + s.hex"/>
                                </div>
                                <span class="mfg-state-count"><t t-esc="s.count"/></span>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- SCM Production by State -->
                <div class="mfg-panel">
                    <h3><i class="fa fa-cogs"/> Fertigungsaufträge (SCM)</h3>
                    <div class="mfg-state-bars">
                        <t t-foreach="scmOrderStates()" t-as="s" t-key="s.key">
                            <div class="mfg-state-bar-row mfg-state-bar-clickable" t-on-click="() => this.openDrilldown('scm_in_progress')">
                                <span class="mfg-state-label"><t t-esc="s.label"/></span>
                                <div class="mfg-bar-track">
                                    <div class="mfg-bar-fill" t-att-style="'width:' + s.pct + '%;background:' + s.hex"/>
                                </div>
                                <span class="mfg-state-count"><t t-esc="s.count"/></span>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- Machine Status — Donut Chart -->
                <div class="mfg-panel mfg-panel-machines">
                    <h3><i class="fa fa-tachometer"/> Maschinenstatus</h3>
                    <div class="mfg-machine-donut-wrap">
                        <!-- SVG Donut -->
                        <div class="mfg-donut-svg-wrap">
                            <svg viewBox="0 0 80 80" width="120" height="120">
                                <t t-if="totalMachines() > 0">
                                    <t t-foreach="donutSegments()" t-as="seg" t-key="seg.state">
                                        <circle cx="40" cy="40" r="28"
                                            fill="none"
                                            t-att-stroke="seg.color"
                                            stroke-width="14"
                                            t-att-stroke-dasharray="seg.dashArray"
                                            t-att-stroke-dashoffset="seg.dashOffset"
                                            stroke-linecap="butt"
                                            style="transform: rotate(-90deg); transform-origin: 50% 50%"/>
                                    </t>
                                </t>
                                <text x="40" y="36" text-anchor="middle" class="mfg-donut-total-num"><t t-esc="totalMachines()"/></text>
                                <text x="40" y="49" text-anchor="middle" class="mfg-donut-total-lbl">gesamt</text>
                            </svg>
                        </div>
                        <!-- Legend -->
                        <div class="mfg-donut-legend">
                            <div class="mfg-donut-legend-item mfg-legend-clickable" t-on-click="() => this.openDrilldown('machines_op')">
                                <span class="mfg-dot state-operational"/> <span>Betrieb</span>
                                <strong class="text-success"><t t-esc="state.data.machines.operational"/></strong>
                                <span class="mfg-donut-pct"><t t-esc="machPct('operational')"/>%</span>
                            </div>
                            <div class="mfg-donut-legend-item">
                                <span class="mfg-dot state-maintenance"/> <span>Wartung</span>
                                <strong class="text-warning"><t t-esc="state.data.machines.maintenance"/></strong>
                                <span class="mfg-donut-pct"><t t-esc="machPct('maintenance')"/>%</span>
                            </div>
                            <div class="mfg-donut-legend-item mfg-legend-clickable" t-on-click="() => this.openDrilldown('machines_fail')">
                                <span class="mfg-dot state-breakdown"/> <span>Störung</span>
                                <strong class="text-danger"><t t-esc="state.data.machines.breakdown"/></strong>
                                <span class="mfg-donut-pct"><t t-esc="machPct('breakdown')"/>%</span>
                            </div>
                            <div class="mfg-donut-legend-item">
                                <span class="mfg-dot state-decommissioned"/> <span>Stillgelegt</span>
                                <strong class="text-muted"><t t-esc="state.data.machines.decommissioned"/></strong>
                                <span class="mfg-donut-pct"><t t-esc="machPct('decommissioned')"/>%</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Deliveries -->
                <div class="mfg-panel">
                    <h3><i class="fa fa-truck"/> Lieferungen</h3>
                    <div class="mfg-state-bars">
                        <t t-foreach="deliveryStates()" t-as="s" t-key="s.key">
                            <div class="mfg-state-bar-row">
                                <span class="mfg-state-label"><t t-esc="s.label"/></span>
                                <div class="mfg-bar-track">
                                    <div class="mfg-bar-fill" t-att-style="'width:' + s.pct + '%;background:' + s.hex"/>
                                </div>
                                <span class="mfg-state-count"><t t-esc="s.count"/></span>
                            </div>
                        </t>
                    </div>
                    <div class="mfg-parts-alert" t-if="state.data.parts.low_stock > 0">
                        <i class="fa fa-warning text-danger"/>
                        <strong><t t-esc="state.data.parts.low_stock"/></strong> Teile ohne Lagerbestand
                    </div>
                </div>
            </div>
        </t>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════════════════
     Production Board
════════════════════════════════════════════════════════════════════ -->
<t t-name="mfg_management.ProductionBoard">
    <div class="mfg-dashboard">
        <div class="mfg-dashboard-header">
            <h1><i class="fa fa-columns"/> Production Board</h1>
            <button class="btn btn-sm btn-outline-secondary" t-on-click="loadData">
                <i class="fa fa-refresh"/> Aktualisieren
            </button>
        </div>

        <t t-if="state.loading">
            <div class="mfg-loading"><i class="fa fa-spinner fa-spin fa-3x"/></div>
        </t>

        <t t-if="!state.loading and state.data">
            <!-- Tab Switcher -->
            <div class="mfg-tab-bar">
                <button class="mfg-tab" t-att-class="state.tab === 'casting' ? 'active' : ''"
                    t-on-click="() => this.state.tab = 'casting'">
                    <i class="fa fa-fire"/> Gießaufträge
                    <span class="mfg-tab-badge"><t t-esc="state.data.casting_orders.length"/></span>
                </button>
                <button class="mfg-tab" t-att-class="state.tab === 'scm' ? 'active' : ''"
                    t-on-click="() => this.state.tab = 'scm'">
                    <i class="fa fa-cogs"/> Fertigungsaufträge
                    <span class="mfg-tab-badge"><t t-esc="state.data.scm_orders.length"/></span>
                </button>
            </div>

            <!-- Casting Kanban -->
            <t t-if="state.tab === 'casting'">
                <div class="mfg-kanban">
                    <t t-foreach="castingColumns()" t-as="col" t-key="col.key">
                        <div class="mfg-kanban-col">
                            <div class="mfg-kanban-col-header" t-att-style="'border-top: 3px solid ' + col.color">
                                <span><t t-esc="col.label"/></span>
                                <span class="mfg-kanban-count"><t t-esc="col.items.length"/></span>
                            </div>
                            <div class="mfg-kanban-cards">
                                <t t-foreach="col.items" t-as="order" t-key="order.id">
                                    <div class="mfg-kanban-card">
                                        <div class="mfg-card-title"><t t-esc="order.name"/></div>
                                        <t t-if="order.customer_reference">
                                            <div class="mfg-card-sub"><i class="fa fa-tag"/> <t t-esc="order.customer_reference"/></div>
                                        </t>
                                        <t t-if="order.date_planned">
                                            <div class="mfg-card-date"><i class="fa fa-calendar"/> <t t-esc="order.date_planned"/></div>
                                        </t>
                                        <t t-if="order.total_pieces">
                                            <div class="mfg-card-meta"><i class="fa fa-cubes"/> <t t-esc="order.total_pieces"/> Stk</div>
                                        </t>
                                        <t t-if="order.total_scrap_pct > 0">
                                            <div class="mfg-card-scrap text-warning"><i class="fa fa-exclamation"/> Ausschuss: <t t-esc="order.total_scrap_pct"/>%</div>
                                        </t>
                                    </div>
                                </t>
                                <t t-if="col.items.length === 0">
                                    <div class="mfg-kanban-empty">— leer —</div>
                                </t>
                            </div>
                        </div>
                    </t>
                </div>
            </t>

            <!-- SCM Kanban -->
            <t t-if="state.tab === 'scm'">
                <div class="mfg-kanban">
                    <t t-foreach="scmColumns()" t-as="col" t-key="col.key">
                        <div class="mfg-kanban-col">
                            <div class="mfg-kanban-col-header" t-att-style="'border-top: 3px solid ' + col.color">
                                <span><t t-esc="col.label"/></span>
                                <span class="mfg-kanban-count"><t t-esc="col.items.length"/></span>
                            </div>
                            <div class="mfg-kanban-cards">
                                <t t-foreach="col.items" t-as="order" t-key="order.id">
                                    <div class="mfg-kanban-card">
                                        <div class="mfg-card-title"><t t-esc="order.name"/></div>
                                        <t t-if="order.part_name">
                                            <div class="mfg-card-sub"><i class="fa fa-cube"/> <t t-esc="order.part_name"/></div>
                                        </t>
                                        <t t-if="order.date_planned">
                                            <div class="mfg-card-date"><i class="fa fa-calendar"/> <t t-esc="order.date_planned"/></div>
                                        </t>
                                        <div class="mfg-card-meta">
                                            <i class="fa fa-cubes"/> <t t-esc="order.produced_qty"/> / <t t-esc="order.planned_qty"/> Stk
                                        </div>
                                        <t t-if="order.planned_qty > 0">
                                            <div class="mfg-progress-bar">
                                                <div class="mfg-progress-fill"
                                                    t-att-style="'width:' + Math.min(100, Math.round(order.produced_qty / order.planned_qty * 100)) + '%'"/>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                                <t t-if="col.items.length === 0">
                                    <div class="mfg-kanban-empty">— leer —</div>
                                </t>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
        </t>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════════════════
     Machine Status Board
════════════════════════════════════════════════════════════════════ -->
<t t-name="mfg_management.MachineStatus">
    <div class="mfg-dashboard">
        <div class="mfg-dashboard-header">
            <h1><i class="fa fa-tachometer"/> Maschinenstatus</h1>
            <div class="mfg-header-controls">
                <select class="form-select form-select-sm mfg-filter-select" t-on-change="onFilterChange">
                    <option value="">Alle Typen</option>
                    <option value="die_casting">Druckguss</option>
                    <option value="gravity_casting">Schwerkraft-Kokillen</option>
                    <option value="sand_molding">Formanlage (Sand)</option>
                    <option value="melting_furnace">Schmelzofen</option>
                    <option value="holding_furnace">Warmhalteofen</option>
                    <option value="heat_treatment">Wärmebehandlung</option>
                    <option value="finishing">Nachbearbeitung</option>
                    <option value="xray">Röntgenprüfung</option>
                </select>
                <button class="btn btn-sm btn-outline-secondary" t-on-click="loadData">
                    <i class="fa fa-refresh"/>
                </button>
            </div>
        </div>

        <t t-if="state.loading">
            <div class="mfg-loading"><i class="fa fa-spinner fa-spin fa-3x"/></div>
        </t>

        <t t-if="!state.loading and state.machines">
            <!-- Status Summary Bar -->
            <div class="mfg-machine-summary">
                <t t-foreach="machineSummary()" t-as="s" t-key="s.state">
                    <div class="mfg-summary-pill" t-att-class="'pill-' + s.state">
                        <span class="pill-count"><t t-esc="s.count"/></span>
                        <span class="pill-label"><t t-esc="s.label"/></span>
                    </div>
                </t>
            </div>

            <!-- Machine Grid -->
            <div class="mfg-machine-grid">
                <t t-foreach="filteredMachines()" t-as="m" t-key="m.id">
                    <div class="mfg-machine-card" t-att-class="'mstate-' + m.state">
                        <div class="mfg-machine-status-dot" t-att-class="'dot-' + m.state"/>
                        <div class="mfg-machine-info">
                            <div class="mfg-machine-name"><t t-esc="m.code"/> — <t t-esc="m.name"/></div>
                            <div class="mfg-machine-type"><t t-esc="machineTypeLabel(m.machine_type)"/></div>
                            <t t-if="m.hall">
                                <div class="mfg-machine-hall"><i class="fa fa-map-marker"/> <t t-esc="m.hall"/></div>
                            </t>
                            <t t-if="m.manufacturer">
                                <div class="mfg-machine-mfr text-muted"><t t-esc="m.manufacturer"/></div>
                            </t>
                        </div>
                        <div class="mfg-machine-state-badge" t-att-class="'sbadge-' + m.state">
                            <t t-esc="stateLabel(m.state)"/>
                        </div>
                    </div>
                </t>
            </div>
        </t>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════════════════
     SCM Overview
════════════════════════════════════════════════════════════════════ -->
<t t-name="mfg_management.ScmOverview">
    <div class="mfg-dashboard">
        <div class="mfg-dashboard-header">
            <h1><i class="fa fa-sitemap"/> SCM Übersicht</h1>
            <button class="btn btn-sm btn-outline-secondary" t-on-click="loadData">
                <i class="fa fa-refresh"/> Aktualisieren
            </button>
        </div>

        <t t-if="state.loading">
            <div class="mfg-loading"><i class="fa fa-spinner fa-spin fa-3x"/></div>
        </t>

        <t t-if="!state.loading and state.data">
            <div class="mfg-scm-grid">

                <!-- Open Purchase Orders -->
                <div class="mfg-panel mfg-panel-wide">
                    <h3><i class="fa fa-shopping-cart"/> Offene Bestellungen (<t t-esc="state.data.open_purchases.length"/>)</h3>
                    <table class="mfg-table">
                        <thead>
                            <tr>
                                <th>Nr.</th>
                                <th>Lieferant</th>
                                <th>Status</th>
                                <th>Bestelldatum</th>
                                <th>Erwartet</th>
                                <th class="text-end">Betrag (€)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.data.open_purchases" t-as="p" t-key="p.id">
                                <tr>
                                    <td class="mfg-monospace"><t t-esc="p.name"/></td>
                                    <td><t t-esc="p.partner_name"/></td>
                                    <td><span class="mfg-badge" t-att-class="'po-' + p.state"><t t-esc="purchaseStateLabel(p.state)"/></span></td>
                                    <td><t t-esc="p.date_order"/></td>
                                    <td t-att-class="isOverdue(p.date_expected) ? 'text-danger fw-bold' : ''">
                                        <t t-esc="p.date_expected || '—'"/>
                                        <t t-if="isOverdue(p.date_expected)"> <i class="fa fa-warning"/></t>
                                    </td>
                                    <td class="text-end"><t t-esc="formatAmount(p.total_amount)"/></td>
                                </tr>
                            </t>
                            <t t-if="state.data.open_purchases.length === 0">
                                <tr><td colspan="6" class="text-center text-muted">Keine offenen Bestellungen</td></tr>
                            </t>
                        </tbody>
                    </table>
                </div>

                <!-- Open Deliveries -->
                <div class="mfg-panel mfg-panel-wide">
                    <h3><i class="fa fa-truck"/> Offene Lieferungen (<t t-esc="state.data.open_deliveries.length"/>)</h3>
                    <table class="mfg-table">
                        <thead>
                            <tr>
                                <th>Nr.</th>
                                <th>Empfänger</th>
                                <th>Status</th>
                                <th>Versand</th>
                                <th>Zustellung</th>
                                <th>Spediteur</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.data.open_deliveries" t-as="d" t-key="d.id">
                                <tr>
                                    <td class="mfg-monospace"><t t-esc="d.name"/></td>
                                    <td><t t-esc="d.partner_name"/></td>
                                    <td><span class="mfg-badge" t-att-class="'del-' + d.state"><t t-esc="deliveryStateLabel(d.state)"/></span></td>
                                    <td><t t-esc="d.date_shipped || '—'"/></td>
                                    <td><t t-esc="d.date_delivered || '—'"/></td>
                                    <td><t t-esc="d.carrier || '—'"/></td>
                                </tr>
                            </t>
                            <t t-if="state.data.open_deliveries.length === 0">
                                <tr><td colspan="6" class="text-center text-muted">Keine offenen Lieferungen</td></tr>
                            </t>
                        </tbody>
                    </table>
                </div>

                <!-- Warehouses -->
                <div class="mfg-panel">
                    <h3><i class="fa fa-warehouse"/> Lager</h3>
                    <div class="mfg-warehouse-cards">
                        <t t-foreach="state.data.warehouses" t-as="w" t-key="w.id">
                            <div class="mfg-warehouse-card">
                                <div class="mfg-wh-code"><t t-esc="w.code"/></div>
                                <div class="mfg-wh-name"><t t-esc="w.name"/></div>
                                <div class="mfg-wh-type"><span class="mfg-badge" t-att-class="'wh-' + w.warehouse_type"><t t-esc="warehouseTypeLabel(w.warehouse_type)"/></span></div>
                                <t t-if="w.capacity_pallets">
                                    <div class="mfg-wh-cap text-muted"><i class="fa fa-th-large"/> <t t-esc="w.capacity_pallets"/> Paletten</div>
                                </t>
                            </div>
                        </t>
                        <t t-if="state.data.warehouses.length === 0">
                            <div class="text-muted">Keine Lager konfiguriert</div>
                        </t>
                    </div>
                </div>

            </div>
        </t>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════════════════
     PanelErrorBoundary — isoliert crashende Panels.
     Verhindert OWL-App-Freeze bei einzelnem Panel-Fehler.
════════════════════════════════════════════════════════════════════ -->
<t t-name="mfg_management.PanelErrorBoundary">
    <t t-if="state.hasError">
        <div class="iil-panel-error">
            <i class="fa fa-exclamation-triangle text-warning me-2"/>
            <span>Panel konnte nicht geladen werden</span>
            <div class="iil-panel-error-detail text-muted small mt-1" t-esc="state.errorMsg"/>
        </div>
    </t>
    <t t-else="">
        <t t-slot="default"/>
    </t>
</t>

<!-- ═══════════════════════════════════════════════════════════════════
     DynamicDashboard — Feature-Registry-gesteuert (iil_configurator)
     Fällt auf statischen MfgDashboard zurück wenn kein Feature aktiv.
     Vollständiges Template — kein t-inherit (Odoo 18 QWeb: leeres primary-
     inherit erzeugt undefined Template → OWL-App einfrieren).
════════════════════════════════════════════════════════════════════ -->
<t t-name="mfg_management.DynamicDashboard">
    <div class="iil-dynamic-dashboard">

        <!-- Lade-Spinner -->
        <t t-if="state.loading">
            <div class="iil-panel-loading">
                <i class="fa fa-spinner fa-spin fa-2x me-2"/>
                Dashboard wird geladen…
            </div>
        </t>

        <!-- Fallback: Keine Panels konfiguriert -->
        <t t-elif="state.fallback">
            <div class="iil-panel-loading">
                <i class="fa fa-info-circle me-2"/>
                Keine Panels aktiv. Bitte den IIL Konfigurator aufrufen.
            </div>
        </t>

        <!-- Dynamische Panels aus Feature-Registry -->
        <t t-else="">
            <div class="iil-dynamic-dashboard-header">
                <h1><i class="fa fa-industry me-2"/><t t-esc="dashboardTitle"/></h1>
            </div>
            <div class="iil-panels-grid">
                <t t-foreach="state.panels" t-as="panel" t-key="panel.code">
                    <div class="iil-panel-card">
                        <div class="iil-panel-card-header">
                            <i t-att-class="'fa fa-' + panel.icon"/>
                            <span t-esc="panel.label"/>
                        </div>
                        <div class="iil-panel-card-body">
                            <PanelErrorBoundary>
                                <t t-component="panel.component"
                                   t-props="{ featureCode: panel.code, featureConfig: panel.config, featureLabel: panel.label }"/>
                            </PanelErrorBoundary>
                        </div>
                    </div>
                </t>
            </div>
        </t>

    </div>
</t>

</templates>
