<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<!-- ═══════════════════════════════════════════════════════════════════
     KPI Card
════════════════════════════════════════════════════════════════════ -->
<t t-name="mfg_management.KpiCard">
    <div class="mfg-kpi-card" t-att-class="props.colorClass or ''">
        <div class="mfg-kpi-icon">
            <i t-att-class="'fa ' + (props.icon or 'fa-bar-chart')"/>
        </div>
        <div class="mfg-kpi-body">
            <div class="mfg-kpi-value"><t t-esc="props.value"/></div>
            <div class="mfg-kpi-label"><t t-esc="props.label"/></div>
            <t t-if="props.sublabel">
                <div class="mfg-kpi-sublabel"><t t-esc="props.sublabel"/></div>
            </t>
        </div>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════════════════
     Main Dashboard (Cockpit)
════════════════════════════════════════════════════════════════════ -->
<t t-name="mfg_management.Dashboard">
    <div class="mfg-dashboard">
        <div class="mfg-dashboard-header">
            <h1><i class="fa fa-industry"/> Manufacturing Cockpit</h1>
            <button class="btn btn-sm btn-outline-secondary" t-on-click="loadData">
                <i class="fa fa-refresh"/> Aktualisieren
            </button>
        </div>

        <t t-if="state.loading">
            <div class="mfg-loading">
                <i class="fa fa-spinner fa-spin fa-3x"/>
                <p>Daten werden geladen…</p>
            </div>
        </t>

        <t t-if="!state.loading and state.data">
            <!-- KPI Row -->
            <div class="mfg-kpi-row">
                <KpiCard
                    icon="'fa-tasks'"
                    label="'Aktive Aufträge (Guss)'"
                    value="activecastingOrders()"
                    colorClass="'kpi-blue'"/>
                <KpiCard
                    icon="'fa-cogs'"
                    label="'Fertigung in Progress'"
                    value="state.data.scm_production.in_progress"
                    colorClass="'kpi-orange'"/>
                <KpiCard
                    icon="'fa-wrench'"
                    label="'Maschinen Betrieb'"
                    value="state.data.machines.operational"
                    colorClass="'kpi-green'"/>
                <KpiCard
                    icon="'fa-exclamation-triangle'"
                    label="'Maschinen Störung'"
                    value="state.data.machines.breakdown"
                    colorClass="'kpi-red'"/>
                <KpiCard
                    icon="'fa-check-circle'"
                    label="'QS-Rate'"
                    value="state.data.quality.pass_rate + '%'"
                    sublabel="state.data.quality.total + ' Prüfungen'"
                    colorClass="'kpi-teal'"/>
                <KpiCard
                    icon="'fa-shopping-cart'"
                    label="'Offene Bestellungen'"
                    value="openPurchases()"
                    colorClass="'kpi-purple'"/>
            </div>

            <!-- Status Overview Grid -->
            <div class="mfg-section-grid">

                <!-- Casting Orders by State -->
                <div class="mfg-panel">
                    <h3><i class="fa fa-fire"/> Gießaufträge</h3>
                    <div class="mfg-state-bars">
                        <t t-foreach="castingOrderStates()" t-as="s" t-key="s.key">
                            <div class="mfg-state-bar-row">
                                <span class="mfg-state-label" t-att-class="'badge-' + s.color"><t t-esc="s.label"/></span>
                                <div class="mfg-bar-track">
                                    <div class="mfg-bar-fill" t-att-style="'width:' + s.pct + '%;background:' + s.hex"/>
                                </div>
                                <span class="mfg-state-count"><t t-esc="s.count"/></span>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- SCM Production by State -->
                <div class="mfg-panel">
                    <h3><i class="fa fa-cogs"/> Fertigungsaufträge (SCM)</h3>
                    <div class="mfg-state-bars">
                        <t t-foreach="scmOrderStates()" t-as="s" t-key="s.key">
                            <div class="mfg-state-bar-row">
                                <span class="mfg-state-label"><t t-esc="s.label"/></span>
                                <div class="mfg-bar-track">
                                    <div class="mfg-bar-fill" t-att-style="'width:' + s.pct + '%;background:' + s.hex"/>
                                </div>
                                <span class="mfg-state-count"><t t-esc="s.count"/></span>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- Machine Status Donut-style -->
                <div class="mfg-panel">
                    <h3><i class="fa fa-tachometer"/> Maschinenstatus</h3>
                    <div class="mfg-machine-legend">
                        <div class="mfg-machine-legend-item state-operational">
                            <span class="mfg-dot"/> Betrieb
                            <strong><t t-esc="state.data.machines.operational"/></strong>
                        </div>
                        <div class="mfg-machine-legend-item state-maintenance">
                            <span class="mfg-dot"/> Wartung
                            <strong><t t-esc="state.data.machines.maintenance"/></strong>
                        </div>
                        <div class="mfg-machine-legend-item state-breakdown">
                            <span class="mfg-dot"/> Störung
                            <strong><t t-esc="state.data.machines.breakdown"/></strong>
                        </div>
                        <div class="mfg-machine-legend-item state-decommissioned">
                            <span class="mfg-dot"/> Stillgelegt
                            <strong><t t-esc="state.data.machines.decommissioned"/></strong>
                        </div>
                    </div>
                    <div class="mfg-machine-bar-stacked">
                        <t t-if="totalMachines() > 0">
                            <div class="mfg-seg seg-operational" t-att-style="'width:' + machPct('operational') + '%'" t-att-title="'Betrieb: ' + state.data.machines.operational"/>
                            <div class="mfg-seg seg-maintenance" t-att-style="'width:' + machPct('maintenance') + '%'" t-att-title="'Wartung: ' + state.data.machines.maintenance"/>
                            <div class="mfg-seg seg-breakdown"   t-att-style="'width:' + machPct('breakdown') + '%'"   t-att-title="'Störung: ' + state.data.machines.breakdown"/>
                            <div class="mfg-seg seg-decomm"      t-att-style="'width:' + machPct('decommissioned') + '%'" t-att-title="'Stillgelegt: ' + state.data.machines.decommissioned"/>
                        </t>
                    </div>
                </div>

                <!-- Quality + Delivery -->
                <div class="mfg-panel">
                    <h3><i class="fa fa-truck"/> Lieferungen</h3>
                    <div class="mfg-state-bars">
                        <t t-foreach="deliveryStates()" t-as="s" t-key="s.key">
                            <div class="mfg-state-bar-row">
                                <span class="mfg-state-label"><t t-esc="s.label"/></span>
                                <div class="mfg-bar-track">
                                    <div class="mfg-bar-fill" t-att-style="'width:' + s.pct + '%;background:' + s.hex"/>
                                </div>
                                <span class="mfg-state-count"><t t-esc="s.count"/></span>
                            </div>
                        </t>
                    </div>
                    <div class="mfg-parts-alert" t-if="state.data.parts.low_stock > 0">
                        <i class="fa fa-warning text-danger"/>
                        <strong><t t-esc="state.data.parts.low_stock"/></strong> Teile ohne Lagerbestand
                    </div>
                </div>
            </div>
        </t>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════════════════
     Production Board
════════════════════════════════════════════════════════════════════ -->
<t t-name="mfg_management.ProductionBoard">
    <div class="mfg-dashboard">
        <div class="mfg-dashboard-header">
            <h1><i class="fa fa-columns"/> Production Board</h1>
            <button class="btn btn-sm btn-outline-secondary" t-on-click="loadData">
                <i class="fa fa-refresh"/> Aktualisieren
            </button>
        </div>

        <t t-if="state.loading">
            <div class="mfg-loading"><i class="fa fa-spinner fa-spin fa-3x"/></div>
        </t>

        <t t-if="!state.loading and state.data">
            <!-- Tab Switcher -->
            <div class="mfg-tab-bar">
                <button class="mfg-tab" t-att-class="state.tab === 'casting' ? 'active' : ''"
                    t-on-click="() => this.state.tab = 'casting'">
                    <i class="fa fa-fire"/> Gießaufträge
                    <span class="mfg-tab-badge"><t t-esc="state.data.casting_orders.length"/></span>
                </button>
                <button class="mfg-tab" t-att-class="state.tab === 'scm' ? 'active' : ''"
                    t-on-click="() => this.state.tab = 'scm'">
                    <i class="fa fa-cogs"/> Fertigungsaufträge
                    <span class="mfg-tab-badge"><t t-esc="state.data.scm_orders.length"/></span>
                </button>
            </div>

            <!-- Casting Kanban -->
            <t t-if="state.tab === 'casting'">
                <div class="mfg-kanban">
                    <t t-foreach="castingColumns()" t-as="col" t-key="col.key">
                        <div class="mfg-kanban-col">
                            <div class="mfg-kanban-col-header" t-att-style="'border-top: 3px solid ' + col.color">
                                <span><t t-esc="col.label"/></span>
                                <span class="mfg-kanban-count"><t t-esc="col.items.length"/></span>
                            </div>
                            <div class="mfg-kanban-cards">
                                <t t-foreach="col.items" t-as="order" t-key="order.id">
                                    <div class="mfg-kanban-card">
                                        <div class="mfg-card-title"><t t-esc="order.name"/></div>
                                        <t t-if="order.customer_reference">
                                            <div class="mfg-card-sub"><i class="fa fa-tag"/> <t t-esc="order.customer_reference"/></div>
                                        </t>
                                        <t t-if="order.date_planned">
                                            <div class="mfg-card-date"><i class="fa fa-calendar"/> <t t-esc="order.date_planned"/></div>
                                        </t>
                                        <t t-if="order.total_pieces">
                                            <div class="mfg-card-meta"><i class="fa fa-cubes"/> <t t-esc="order.total_pieces"/> Stk</div>
                                        </t>
                                        <t t-if="order.total_scrap_pct > 0">
                                            <div class="mfg-card-scrap text-warning"><i class="fa fa-exclamation"/> Ausschuss: <t t-esc="order.total_scrap_pct"/>%</div>
                                        </t>
                                    </div>
                                </t>
                                <t t-if="col.items.length === 0">
                                    <div class="mfg-kanban-empty">— leer —</div>
                                </t>
                            </div>
                        </div>
                    </t>
                </div>
            </t>

            <!-- SCM Kanban -->
            <t t-if="state.tab === 'scm'">
                <div class="mfg-kanban">
                    <t t-foreach="scmColumns()" t-as="col" t-key="col.key">
                        <div class="mfg-kanban-col">
                            <div class="mfg-kanban-col-header" t-att-style="'border-top: 3px solid ' + col.color">
                                <span><t t-esc="col.label"/></span>
                                <span class="mfg-kanban-count"><t t-esc="col.items.length"/></span>
                            </div>
                            <div class="mfg-kanban-cards">
                                <t t-foreach="col.items" t-as="order" t-key="order.id">
                                    <div class="mfg-kanban-card">
                                        <div class="mfg-card-title"><t t-esc="order.name"/></div>
                                        <t t-if="order.part_name">
                                            <div class="mfg-card-sub"><i class="fa fa-cube"/> <t t-esc="order.part_name"/></div>
                                        </t>
                                        <t t-if="order.date_planned">
                                            <div class="mfg-card-date"><i class="fa fa-calendar"/> <t t-esc="order.date_planned"/></div>
                                        </t>
                                        <div class="mfg-card-meta">
                                            <i class="fa fa-cubes"/> <t t-esc="order.produced_qty"/> / <t t-esc="order.planned_qty"/> Stk
                                        </div>
                                        <t t-if="order.planned_qty > 0">
                                            <div class="mfg-progress-bar">
                                                <div class="mfg-progress-fill"
                                                    t-att-style="'width:' + Math.min(100, Math.round(order.produced_qty / order.planned_qty * 100)) + '%'"/>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                                <t t-if="col.items.length === 0">
                                    <div class="mfg-kanban-empty">— leer —</div>
                                </t>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
        </t>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════════════════
     Machine Status Board
════════════════════════════════════════════════════════════════════ -->
<t t-name="mfg_management.MachineStatus">
    <div class="mfg-dashboard">
        <div class="mfg-dashboard-header">
            <h1><i class="fa fa-tachometer"/> Maschinenstatus</h1>
            <div class="mfg-header-controls">
                <select class="form-select form-select-sm mfg-filter-select" t-on-change="onFilterChange">
                    <option value="">Alle Typen</option>
                    <option value="die_casting">Druckguss</option>
                    <option value="gravity_casting">Schwerkraft-Kokillen</option>
                    <option value="sand_molding">Formanlage (Sand)</option>
                    <option value="melting_furnace">Schmelzofen</option>
                    <option value="holding_furnace">Warmhalteofen</option>
                    <option value="heat_treatment">Wärmebehandlung</option>
                    <option value="finishing">Nachbearbeitung</option>
                    <option value="xray">Röntgenprüfung</option>
                </select>
                <button class="btn btn-sm btn-outline-secondary" t-on-click="loadData">
                    <i class="fa fa-refresh"/>
                </button>
            </div>
        </div>

        <t t-if="state.loading">
            <div class="mfg-loading"><i class="fa fa-spinner fa-spin fa-3x"/></div>
        </t>

        <t t-if="!state.loading and state.machines">
            <!-- Status Summary Bar -->
            <div class="mfg-machine-summary">
                <t t-foreach="machineSummary()" t-as="s" t-key="s.state">
                    <div class="mfg-summary-pill" t-att-class="'pill-' + s.state">
                        <span class="pill-count"><t t-esc="s.count"/></span>
                        <span class="pill-label"><t t-esc="s.label"/></span>
                    </div>
                </t>
            </div>

            <!-- Machine Grid -->
            <div class="mfg-machine-grid">
                <t t-foreach="filteredMachines()" t-as="m" t-key="m.id">
                    <div class="mfg-machine-card" t-att-class="'mstate-' + m.state">
                        <div class="mfg-machine-status-dot" t-att-class="'dot-' + m.state"/>
                        <div class="mfg-machine-info">
                            <div class="mfg-machine-name"><t t-esc="m.code"/> — <t t-esc="m.name"/></div>
                            <div class="mfg-machine-type"><t t-esc="machineTypeLabel(m.machine_type)"/></div>
                            <t t-if="m.hall">
                                <div class="mfg-machine-hall"><i class="fa fa-map-marker"/> <t t-esc="m.hall"/></div>
                            </t>
                            <t t-if="m.manufacturer">
                                <div class="mfg-machine-mfr text-muted"><t t-esc="m.manufacturer"/></div>
                            </t>
                        </div>
                        <div class="mfg-machine-state-badge" t-att-class="'sbadge-' + m.state">
                            <t t-esc="stateLabel(m.state)"/>
                        </div>
                    </div>
                </t>
            </div>
        </t>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════════════════
     SCM Overview
════════════════════════════════════════════════════════════════════ -->
<t t-name="mfg_management.ScmOverview">
    <div class="mfg-dashboard">
        <div class="mfg-dashboard-header">
            <h1><i class="fa fa-sitemap"/> SCM Übersicht</h1>
            <button class="btn btn-sm btn-outline-secondary" t-on-click="loadData">
                <i class="fa fa-refresh"/> Aktualisieren
            </button>
        </div>

        <t t-if="state.loading">
            <div class="mfg-loading"><i class="fa fa-spinner fa-spin fa-3x"/></div>
        </t>

        <t t-if="!state.loading and state.data">
            <div class="mfg-scm-grid">

                <!-- Open Purchase Orders -->
                <div class="mfg-panel mfg-panel-wide">
                    <h3><i class="fa fa-shopping-cart"/> Offene Bestellungen (<t t-esc="state.data.open_purchases.length"/>)</h3>
                    <table class="mfg-table">
                        <thead>
                            <tr>
                                <th>Nr.</th>
                                <th>Lieferant</th>
                                <th>Status</th>
                                <th>Bestelldatum</th>
                                <th>Erwartet</th>
                                <th class="text-end">Betrag (€)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.data.open_purchases" t-as="p" t-key="p.id">
                                <tr>
                                    <td class="mfg-monospace"><t t-esc="p.name"/></td>
                                    <td><t t-esc="p.partner_name"/></td>
                                    <td><span class="mfg-badge" t-att-class="'po-' + p.state"><t t-esc="purchaseStateLabel(p.state)"/></span></td>
                                    <td><t t-esc="p.date_order"/></td>
                                    <td t-att-class="isOverdue(p.date_expected) ? 'text-danger fw-bold' : ''">
                                        <t t-esc="p.date_expected || '—'"/>
                                        <t t-if="isOverdue(p.date_expected)"> <i class="fa fa-warning"/></t>
                                    </td>
                                    <td class="text-end"><t t-esc="formatAmount(p.total_amount)"/></td>
                                </tr>
                            </t>
                            <t t-if="state.data.open_purchases.length === 0">
                                <tr><td colspan="6" class="text-center text-muted">Keine offenen Bestellungen</td></tr>
                            </t>
                        </tbody>
                    </table>
                </div>

                <!-- Open Deliveries -->
                <div class="mfg-panel mfg-panel-wide">
                    <h3><i class="fa fa-truck"/> Offene Lieferungen (<t t-esc="state.data.open_deliveries.length"/>)</h3>
                    <table class="mfg-table">
                        <thead>
                            <tr>
                                <th>Nr.</th>
                                <th>Empfänger</th>
                                <th>Status</th>
                                <th>Versand</th>
                                <th>Zustellung</th>
                                <th>Spediteur</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.data.open_deliveries" t-as="d" t-key="d.id">
                                <tr>
                                    <td class="mfg-monospace"><t t-esc="d.name"/></td>
                                    <td><t t-esc="d.partner_name"/></td>
                                    <td><span class="mfg-badge" t-att-class="'del-' + d.state"><t t-esc="deliveryStateLabel(d.state)"/></span></td>
                                    <td><t t-esc="d.date_shipped || '—'"/></td>
                                    <td><t t-esc="d.date_delivered || '—'"/></td>
                                    <td><t t-esc="d.carrier || '—'"/></td>
                                </tr>
                            </t>
                            <t t-if="state.data.open_deliveries.length === 0">
                                <tr><td colspan="6" class="text-center text-muted">Keine offenen Lieferungen</td></tr>
                            </t>
                        </tbody>
                    </table>
                </div>

                <!-- Warehouses -->
                <div class="mfg-panel">
                    <h3><i class="fa fa-warehouse"/> Lager</h3>
                    <div class="mfg-warehouse-cards">
                        <t t-foreach="state.data.warehouses" t-as="w" t-key="w.id">
                            <div class="mfg-warehouse-card">
                                <div class="mfg-wh-code"><t t-esc="w.code"/></div>
                                <div class="mfg-wh-name"><t t-esc="w.name"/></div>
                                <div class="mfg-wh-type"><span class="mfg-badge" t-att-class="'wh-' + w.warehouse_type"><t t-esc="warehouseTypeLabel(w.warehouse_type)"/></span></div>
                                <t t-if="w.capacity_pallets">
                                    <div class="mfg-wh-cap text-muted"><i class="fa fa-th-large"/> <t t-esc="w.capacity_pallets"/> Paletten</div>
                                </t>
                            </div>
                        </t>
                        <t t-if="state.data.warehouses.length === 0">
                            <div class="text-muted">Keine Lager konfiguriert</div>
                        </t>
                    </div>
                </div>

            </div>
        </t>
    </div>
</t>

</templates>
