<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="mfg_management.NL2SqlQueryBar">
    <div class="iil-nl2sql-bar">

        <!-- Toggle-Button -->
        <button class="iil-nl2sql-toggle-btn" t-on-click="toggle">
            <i class="fa fa-magic me-1"/>
            <t t-esc="props.title"/>
            <i t-att-class="'fa fa-chevron-' + (state.open ? 'up' : 'down') + ' ms-2'"/>
        </button>

        <!-- Aufgeklappter Query-Bereich -->
        <t t-if="state.open">
            <div class="iil-nl2sql-body">

                <!-- Query-Eingabe -->
                <div class="iil-nl2sql-input-row">
                    <input type="text"
                           class="iil-nl2sql-input"
                           placeholder="Frage in natürlicher Sprache …"
                           t-att-value="state.query"
                           t-on-input="onInput"
                           t-on-keydown="onKeydown"/>
                    <button class="iil-nl2sql-run-btn"
                            t-att-disabled="state.loading || !state.query.trim()"
                            t-on-click="runQuery">
                        <t t-if="state.loading">
                            <i class="fa fa-spinner fa-spin"/>
                        </t>
                        <t t-else="">
                            <i class="fa fa-search me-1"/> Abfragen
                        </t>
                    </button>
                    <t t-if="state.result or state.error">
                        <button class="iil-nl2sql-clear-btn" t-on-click="clearResult" title="Zurücksetzen">
                            <i class="fa fa-times"/>
                        </button>
                    </t>
                </div>

                <!-- Vorschläge -->
                <t t-if="!state.result and !state.error and props.suggestQueries.length">
                    <div class="iil-nl2sql-suggests">
                        <t t-foreach="props.suggestQueries" t-as="s" t-key="s">
                            <button class="iil-nl2sql-suggest-chip" t-on-click="() => applySuggest(s)">
                                <i class="fa fa-lightbulb-o me-1"/>
                                <t t-esc="s"/>
                            </button>
                        </t>
                    </div>
                </t>

                <!-- Fehler -->
                <t t-if="state.error">
                    <div class="iil-nl2sql-error">
                        <i class="fa fa-exclamation-circle me-1"/>
                        <t t-esc="state.error"/>
                    </div>
                    <t t-if="state.sql">
                        <div class="iil-nl2sql-sql-box"><pre><t t-esc="state.sql"/></pre></div>
                    </t>
                </t>

                <!-- Ergebnis -->
                <t t-if="state.result">
                    <div class="iil-nl2sql-meta">
                        <strong><t t-esc="state.result.row_count"/> Zeilen</strong>
                        <span class="ms-2 text-muted"><t t-esc="state.result.execution_time_ms"/> ms</span>
                        <t t-if="state.result.truncated"><span class="ms-1 text-warning">(gekürzt)</span></t>
                        <t t-if="state.result.summary">
                            <span class="ms-2 iil-nl2sql-summary"><t t-esc="state.result.summary"/></span>
                        </t>
                    </div>

                    <!-- SQL anzeigen -->
                    <t t-if="state.sql">
                        <div class="iil-nl2sql-sql-box"><pre><t t-esc="state.sql"/></pre></div>
                    </t>

                    <!-- Tabelle -->
                    <t t-if="hasRows()">
                        <div class="iil-nl2sql-table-wrap">
                            <table class="iil-nl2sql-table table table-sm table-hover">
                                <thead>
                                    <tr>
                                        <t t-foreach="state.result.columns" t-as="col" t-key="col.name">
                                            <th><t t-esc="col.name"/></th>
                                        </t>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.result.rows" t-as="row" t-key="row_index">
                                        <tr>
                                            <t t-foreach="row" t-as="cell" t-key="cell_index">
                                                <td><t t-esc="cell ?? ''"/></td>
                                            </t>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                    <t t-elif="state.result">
                        <div class="iil-nl2sql-empty"><i class="fa fa-info-circle me-1"/> Keine Ergebnisse</div>
                    </t>
                </t>

            </div>
        </t>
    </div>
</t>

</templates>
