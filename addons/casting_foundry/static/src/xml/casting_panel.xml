<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="casting_foundry.CastingPanel">
    <div class="iil-casting-panel">
        <t t-if="state.loading">
            <div class="iil-panel-loading"><i class="fa fa-spinner fa-spin"/> Lade Gießerei-Daten…</div>
        </t>
        <t t-elif="state.error">
            <div class="iil-panel-error"><i class="fa fa-exclamation-triangle"/> <t t-esc="state.error"/></div>
        </t>
        <t t-else="">
            <!-- KPI-Zeile -->
            <div class="iil-kpi-row">
                <div class="iil-kpi-card">
                    <div class="iil-kpi-value"><t t-esc="activeOrders()"/></div>
                    <div class="iil-kpi-label">Aktive Aufträge</div>
                </div>
                <div class="iil-kpi-card">
                    <div class="iil-kpi-value"><t t-esc="machineAvailabilityPct()"/>%</div>
                    <div class="iil-kpi-label">Maschinenverfügbarkeit</div>
                    <div class="iil-kpi-sub"><t t-esc="state.kpis.machine_states.operational"/> / <t t-esc="totalMachines()"/> Maschinen</div>
                </div>
                <div t-att-class="'iil-kpi-card iil-trend-' + qcTrend()">
                    <div class="iil-kpi-value"><t t-esc="state.kpis.qc_rate"/>%</div>
                    <div class="iil-kpi-label">QS-Bestehensrate</div>
                    <div class="iil-kpi-sub">VM: <t t-esc="state.kpis.qc_rate_last_month"/>% (<t t-esc="state.kpis.qc_total"/> Prüfungen)</div>
                </div>
                <div t-att-class="'iil-kpi-card iil-trend-' + scrapTrend()">
                    <div class="iil-kpi-value"><t t-esc="state.kpis.scrap_avg"/>%</div>
                    <div class="iil-kpi-label">Ø Ausschuss</div>
                    <div class="iil-kpi-sub">VM: <t t-esc="state.kpis.scrap_avg_lm"/>%</div>
                </div>
            </div>

            <!-- Auftrags-Status -->
            <div class="iil-section-title">Aufträge nach Status</div>
            <div class="iil-status-bar-row">
                <t t-foreach="orderStates()" t-as="s" t-key="s.key">
                    <div class="iil-status-chip" t-att-style="'background:' + s.hex">
                        <span class="iil-status-count"><t t-esc="s.count"/></span>
                        <span class="iil-status-label"><t t-esc="s.label"/></span>
                    </div>
                </t>
            </div>

            <!-- Maschinenauslastung -->
            <div class="iil-section-title">Maschinenauslastung</div>
            <div class="iil-machine-list">
                <t t-foreach="state.kpis.machine_load" t-as="m" t-key="m.id">
                    <div class="iil-machine-row">
                        <span class="iil-machine-state-dot" t-att-style="'background:' + machineStateColor(m.state)"/>
                        <span class="iil-machine-name"><t t-esc="m.name"/></span>
                        <span class="iil-machine-hall"><t t-esc="m.hall"/></span>
                        <span class="iil-machine-orders"><t t-esc="m.active_orders"/> Auftr.</span>
                    </div>
                </t>
                <t t-if="!state.kpis.machine_load.length">
                    <div class="iil-empty">Keine aktiven Aufträge</div>
                </t>
            </div>
        </t>
    </div>
</t>

</templates>
