<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dashboard_config_form" model="ir.ui.view">
        <field name="name">nl2sql.dashboard.config.form</field>
        <field name="model">nl2sql.dashboard.config</field>
        <field name="arch" type="xml">
            <form string="Dashboard-Einstellungen">
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="default_domain"/>
                            <field name="theme"/>
                        </group>
                        <group>
                            <field name="show_sql"/>
                            <field name="max_results"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dashboard_config_list" model="ir.ui.view">
        <field name="name">nl2sql.dashboard.config.list</field>
        <field name="model">nl2sql.dashboard.config</field>
        <field name="arch" type="xml">
            <list string="Dashboard-Einstellungen">
                <field name="user_id"/>
                <field name="default_domain"/>
                <field name="show_sql"/>
                <field name="max_results"/>
                <field name="theme"/>
            </list>
        </field>
    </record>

    <record id="action_dashboard_config" model="ir.actions.act_window">
        <field name="name">Dashboard-Einstellungen</field>
        <field name="res_model">nl2sql.dashboard.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
