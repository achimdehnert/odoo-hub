<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            NL2SQL Schema-Metadaten für die Werkzeugmaschinen-Domain (mfg_machining)
            Wird vom IIL-Seed-Engine via _activate_nl2sql_schema('machining') aktiviert.
            Nur geladen wenn mfg_machining installiert ist — depends in __manifest__ nicht nötig,
            da is_active=False per Default (kein Schaden wenn Modul fehlt).
        -->

        <!-- ── machining.order ───────────────────────────────────────────────── -->
        <record id="schema_table_machining_order" model="nl2sql.schema.table">
            <field name="name">machining_order</field>
            <field name="model_name">machining.order</field>
            <field name="domain">machining</field>
            <field name="is_active">False</field>
            <field name="description">CNC-Fertigungsaufträge — Bearbeitungsaufträge für Werkzeugmaschinen mit Status, Maschine, Mengen und Ausschuss.</field>
            <field name="sample_queries">Wie viele CNC-Aufträge sind aktuell in Fertigung?
Durchschnittliche Zykluszeit pro Maschinentyp
Aufträge mit höchstem Ausschuss letzte 3 Monate
Fertigungsvolumen pro Monat im Vergleich zum Vorjahr
Welche Maschine hat die meisten Aufträge?</field>
        </record>

        <record id="schema_col_mo_name" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_order"/>
            <field name="name">name</field>
            <field name="data_type">varchar</field>
            <field name="description">Auftragsnummer (z.B. MO/2025/0001)</field>
            <field name="sequence">1</field>
        </record>

        <record id="schema_col_mo_state" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_order"/>
            <field name="name">state</field>
            <field name="data_type">selection</field>
            <field name="description">Auftragsstatus</field>
            <field name="selection_values">draft,confirmed,in_production,quality_check,done,cancelled</field>
            <field name="sequence">2</field>
        </record>

        <record id="schema_col_mo_machine_id" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_order"/>
            <field name="name">machine_id</field>
            <field name="data_type">many2one</field>
            <field name="description">CNC-Maschine (FK → machining_machine.id)</field>
            <field name="foreign_key_table">machining_machine</field>
            <field name="sequence">3</field>
        </record>

        <record id="schema_col_mo_partner_id" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_order"/>
            <field name="name">partner_id</field>
            <field name="data_type">many2one</field>
            <field name="description">Kunden-ID (FK → res_partner.id)</field>
            <field name="foreign_key_table">res_partner</field>
            <field name="sequence">4</field>
        </record>

        <record id="schema_col_mo_date_planned" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_order"/>
            <field name="name">date_planned</field>
            <field name="data_type">date</field>
            <field name="description">Geplantes Fertigstellungsdatum</field>
            <field name="sequence">5</field>
        </record>

        <record id="schema_col_mo_date_done" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_order"/>
            <field name="name">date_done</field>
            <field name="data_type">datetime</field>
            <field name="description">Tatsächliches Fertigstellungsdatum/-uhrzeit</field>
            <field name="sequence">6</field>
        </record>

        <record id="schema_col_mo_planned_qty" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_order"/>
            <field name="name">planned_qty</field>
            <field name="data_type">integer</field>
            <field name="description">Geplante Stückzahl</field>
            <field name="sequence">7</field>
        </record>

        <record id="schema_col_mo_produced_qty" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_order"/>
            <field name="name">produced_qty</field>
            <field name="data_type">integer</field>
            <field name="description">Tatsächlich produzierte Stückzahl</field>
            <field name="sequence">8</field>
        </record>

        <record id="schema_col_mo_scrap_qty" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_order"/>
            <field name="name">scrap_qty</field>
            <field name="data_type">integer</field>
            <field name="description">Ausschuss in Stück</field>
            <field name="sequence">9</field>
        </record>

        <record id="schema_col_mo_cycle_time_min" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_order"/>
            <field name="name">cycle_time_min</field>
            <field name="data_type">float</field>
            <field name="description">Zykluszeit in Minuten pro Bearbeitungsvorgang</field>
            <field name="sequence">10</field>
        </record>

        <record id="schema_col_mo_material" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_order"/>
            <field name="name">material</field>
            <field name="data_type">varchar</field>
            <field name="description">Werkstoff / Material (z.B. Stahl 42CrMo4, AlSi10Mg)</field>
            <field name="sequence">11</field>
        </record>

        <record id="schema_col_mo_is_demo_data" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_order"/>
            <field name="name">is_demo_data</field>
            <field name="data_type">boolean</field>
            <field name="description">True wenn vom IIL-Seed-Engine generiert — in Produktivabfragen ausschließen: WHERE is_demo_data = false</field>
            <field name="sequence">12</field>
        </record>

        <!-- ── machining.machine ─────────────────────────────────────────────── -->
        <record id="schema_table_machining_machine" model="nl2sql.schema.table">
            <field name="name">machining_machine</field>
            <field name="model_name">machining.machine</field>
            <field name="domain">machining</field>
            <field name="is_active">False</field>
            <field name="description">CNC-Maschinen und Bearbeitungszentren — Maschinenpark mit Typ, Achsanzahl, Spindeldrehzahl, Status und Wartungsintervallen.</field>
            <field name="sample_queries">Welche Maschinen haben aktuell eine Störung?
5-Achs-Maschinen nach letzter Wartung sortiert
Maschinenauslastung nach Typ
Maschinen mit überfälliger Wartung</field>
        </record>

        <record id="schema_col_mm_name" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_machine"/>
            <field name="name">name</field>
            <field name="data_type">varchar</field>
            <field name="description">Maschinenbezeichnung</field>
            <field name="sequence">1</field>
        </record>

        <record id="schema_col_mm_code" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_machine"/>
            <field name="name">code</field>
            <field name="data_type">varchar</field>
            <field name="description">Maschinen-Nummer (eindeutig)</field>
            <field name="sequence">2</field>
        </record>

        <record id="schema_col_mm_machine_type" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_machine"/>
            <field name="name">machine_type</field>
            <field name="data_type">selection</field>
            <field name="description">Maschinentyp</field>
            <field name="selection_values">lathe,milling,machining_center,grinding,drilling,edm,laser,measuring</field>
            <field name="sequence">3</field>
        </record>

        <record id="schema_col_mm_state" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_machine"/>
            <field name="name">state</field>
            <field name="data_type">selection</field>
            <field name="description">Maschinenstatus</field>
            <field name="selection_values">operational,maintenance,breakdown,decommissioned</field>
            <field name="sequence">4</field>
        </record>

        <record id="schema_col_mm_axes" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_machine"/>
            <field name="name">axes</field>
            <field name="data_type">integer</field>
            <field name="description">Anzahl CNC-Achsen (3, 4 oder 5)</field>
            <field name="sequence">5</field>
        </record>

        <record id="schema_col_mm_last_maintenance" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_machine"/>
            <field name="name">last_maintenance</field>
            <field name="data_type">date</field>
            <field name="description">Datum der letzten Wartung</field>
            <field name="sequence">6</field>
        </record>

        <record id="schema_col_mm_next_maintenance" model="nl2sql.schema.column">
            <field name="table_id" ref="schema_table_machining_machine"/>
            <field name="name">next_maintenance</field>
            <field name="data_type">date</field>
            <field name="description">Datum der nächsten geplanten Wartung</field>
            <field name="sequence">7</field>
        </record>

    </data>
</odoo>
