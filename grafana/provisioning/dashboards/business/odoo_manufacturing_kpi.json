{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL (odoo)",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "title": "Odoo — Business KPIs",
  "uid": "odoo-kpi-v1",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["odoo", "manufacturing", "casting", "scm", "kpi"],
  "timezone": "Europe/Berlin",
  "refresh": "10m",
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "templating": {
    "list": [
      {
        "name": "state",
        "type": "custom",
        "label": "MRP Status",
        "query": "draft,confirmed,progress,to_close,done,cancel",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Fertigungsaufträge gesamt (Zeitraum)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Aufträge\" FROM mrp_production WHERE create_date >= $__timeFrom() AND create_date <= $__timeTo()",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 2,
      "title": "Offene Fertigungsaufträge",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Offen\" FROM mrp_production WHERE state IN ('confirmed','progress') AND create_date >= $__timeFrom() AND create_date <= $__timeTo()",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 50 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 3,
      "title": "Casting Aufträge gesamt",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Casting Aufträge\" FROM casting_order WHERE create_date >= $__timeFrom() AND create_date <= $__timeTo()",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 4,
      "title": "Casting Defect Rate (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT ROUND(100.0 * COUNT(cd.id) / NULLIF(COUNT(DISTINCT co.id), 0), 2) AS \"Defect Rate (%)\" FROM casting_order co LEFT JOIN casting_defect cd ON cd.casting_order_id = co.id WHERE co.create_date >= $__timeFrom() AND co.create_date <= $__timeTo()",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 5,
      "title": "Offene Einkaufsbestellungen",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Offene Bestellungen\" FROM purchase_order WHERE state IN ('purchase','draft','sent') AND date_order >= $__timeFrom() AND date_order <= $__timeTo()",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 6,
      "title": "Qualitätsprüfungen offen",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Offene Prüfungen\" FROM quality_check WHERE quality_state = 'none'",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 30 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 7,
      "title": "Fertigungsaufträge pro Tag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT date_trunc('day', create_date) AS time, COUNT(*) AS \"Aufträge\" FROM mrp_production WHERE $__timeFilter(create_date) GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 8,
      "title": "Fertigungsaufträge nach Status",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT state AS \"Status\", COUNT(*) AS \"Anzahl\" FROM mrp_production WHERE $__timeFilter(create_date) GROUP BY state ORDER BY 2 DESC",
        "format": "table"
      }],
      "options": { "pieType": "pie", "displayLabels": ["name", "percent"], "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 9,
      "title": "Casting Aufträge pro Tag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT date_trunc('day', create_date) AS time, COUNT(*) AS \"Casting Aufträge\" FROM casting_order WHERE $__timeFilter(create_date) GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 10,
      "title": "Casting Defekte nach Typ",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT name AS \"Defekttyp\", COUNT(*) AS \"Anzahl\" FROM casting_defect WHERE $__timeFilter(create_date) GROUP BY name ORDER BY 2 DESC LIMIT 15",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "barWidth": 0.7, "xTickLabelRotation": -45, "legend": { "displayMode": "hidden" } }
    },
    {
      "id": 11,
      "title": "Lagerbestand Top-20 Produkte (aktuell)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT pt.name->>'de_DE' AS \"Produkt\", SUM(sq.quantity) AS \"Bestand\", SUM(sq.reserved_quantity) AS \"Reserviert\", SUM(sq.quantity - sq.reserved_quantity) AS \"Verfügbar\" FROM stock_quant sq JOIN product_product pp ON pp.id = sq.product_id JOIN product_template pt ON pt.id = pp.product_tmpl_id JOIN stock_location sl ON sl.id = sq.location_id WHERE sl.usage = 'internal' GROUP BY pt.name ORDER BY 2 DESC LIMIT 20",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "sortBy": [{ "displayName": "Bestand", "desc": true }] }
    },
    {
      "id": 12,
      "title": "Einkaufsbestellungen pro Tag (Wert)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT date_trunc('day', date_order) AS time, SUM(amount_total) AS \"Bestellwert (EUR)\" FROM purchase_order WHERE $__timeFilter(date_order) AND state != 'cancel' GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyEUR", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 13,
      "title": "Qualitätsprüfungen Ergebnis (Zeitraum)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT CASE quality_state WHEN 'pass' THEN 'Bestanden' WHEN 'fail' THEN 'Fehlgeschlagen' WHEN 'none' THEN 'Ausstehend' ELSE quality_state END AS \"Ergebnis\", COUNT(*) AS \"Anzahl\" FROM quality_check WHERE $__timeFilter(create_date) GROUP BY quality_state ORDER BY 2 DESC",
        "format": "table"
      }],
      "options": { "pieType": "donut", "displayLabels": ["name", "percent"], "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 14,
      "title": "Top 10 Lieferanten nach Bestellwert",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 28 },
      "datasource": { "type": "postgres", "uid": "odoo_pg" },
      "targets": [{
        "rawSql": "SELECT rp.name AS \"Lieferant\", SUM(po.amount_total) AS \"Bestellwert (EUR)\" FROM purchase_order po JOIN res_partner rp ON rp.id = po.partner_id WHERE $__timeFilter(po.date_order) AND po.state != 'cancel' GROUP BY rp.name ORDER BY 2 DESC LIMIT 10",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyEUR" } },
      "options": { "barWidth": 0.7, "xTickLabelRotation": -45, "legend": { "displayMode": "hidden" } }
    }
  ],
  "annotations": { "list": [{ "name": "Deployments", "type": "dashboard", "enable": true, "hide": false, "iconColor": "blue" }] }
}
