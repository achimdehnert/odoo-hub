# secrets.enc.env.example — Manifest aller Required Secrets (ADR-045)
#
# Diese Datei ist KEIN Plaintext-Secret — nur Dokumentation der Keys.
# Das verschlüsselte secrets.enc.env wird mit scripts/create-secrets.sh erstellt.
#
# Required Secrets (müssen in secrets.enc.env vorhanden sein):
#   -> SOPS-Verschlüsselung: sops -e --input-type dotenv --output-type dotenv /dev/stdin > secrets.enc.env
#   -> Interaktiv:           ./scripts/create-secrets.sh

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=odoo
POSTGRES_PASSWORD=REQUIRED_min16chars
POSTGRES_DB=odoo

# ── Odoo ──────────────────────────────────────────────────────────────────────
ODOO_ADMIN_PASSWD=REQUIRED_master_password_for_odoo_db_manager
ODOO_DOMAIN=REQUIRED_e.g._odoo.example.com
ACME_EMAIL=REQUIRED_letsencrypt_notification_email

# ── Externe APIs ──────────────────────────────────────────────────────────────
SCHUTZTAT_DJANGO_API_KEY=OPTIONAL
DEPLOYMENT_MCP_ODOO=OPTIONAL_hetzner_mcp_api_key

# ── NL2SQL DB User ────────────────────────────────────────────────────────────
# Wird nach erstem docker compose up gesetzt:
#   docker exec odoo_db psql -U $POSTGRES_USER -d $POSTGRES_DB \
#     -c "ALTER USER nl2sql_user PASSWORD '...'"
NL2SQL_USER_PASSWORD=OPTIONAL_set_after_first_deploy
