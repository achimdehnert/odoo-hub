# .env.staging.example — Staging Stack Environment Variables
# Kopieren: cp .env.staging.example .env.staging  (nicht committen!)
#
# Staging V18: stagingv18-odoo.iil.pet
# Staging V19: stagingv19-odoo.iil.pet

# ── Allgemein ──────────────────────────────────────────────────────────────────
ACME_EMAIL=admin@iil.pet

# ── Staging V18 ───────────────────────────────────────────────────────────────
STAGING_V18_DOMAIN=stagingv18-odoo.iil.pet
STAGING_V18_GRAFANA_DOMAIN=grafana-stagingv18-odoo.iil.pet
STAGING_V18_DB_USER=odoo
STAGING_V18_DB_NAME=odoo_staging_v18
STAGING_V18_DB_PASSWORD=CHANGEME_staging_v18_db

# ── Staging V19 ───────────────────────────────────────────────────────────────
STAGING_V19_DOMAIN=stagingv19-odoo.iil.pet
STAGING_V19_GRAFANA_DOMAIN=grafana-stagingv19-odoo.iil.pet
STAGING_V19_DB_USER=odoo
STAGING_V19_DB_NAME=odoo_staging_v19
STAGING_V19_DB_PASSWORD=CHANGEME_staging_v19_db

# ── Grafana (geteilt für beide Stagings) ──────────────────────────────────────
STAGING_GRAFANA_ADMIN_PASSWORD=CHANGEME_staging_grafana_admin
STAGING_GRAFANA_RO_USER=grafana_ro
STAGING_GRAFANA_RO_PASSWORD=CHANGEME_staging_grafana_ro
